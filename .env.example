# Copy this file to ".env" and fill in your key to enable Claude-generated answers.
# Without a key, the app falls back to the rule-based extractive answer engine.

# Your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for answer generation.
# Default is claude-opus-4-8. For a cheaper / faster demo, use claude-haiku-4-5.
# RAG_LLM_MODEL=claude-opus-4-8
